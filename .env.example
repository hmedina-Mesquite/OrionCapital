# Supabase — public (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://gtncjcbjwmybcvgoivbd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_5clxwvJqR3EsPi73rKlzSQ_PJRHx4iX

# Supabase — server only. Paste manually, NEVER commit.
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_NAME=Orion Capital
NEXT_PUBLIC_APP_TZ=America/Monterrey
NEXT_PUBLIC_APP_LOCALE=es-MX
NEXT_PUBLIC_APP_CURRENCY=MXN

# Google Drive OAuth (optional). When unset, /admin/settings shows a
# "Sin configurar" banner. Get values from Google Cloud Console:
#   1. Create / pick a project
#   2. Enable Google Drive API
#   3. OAuth consent screen → External / Internal, add yourself as test user
#   4. Credentials → Create OAuth client → Web application
#   5. Authorized redirect URIs:
#       http://localhost:3000/api/google/callback   (dev)
#       https://your-prod-domain/api/google/callback  (prod, when deployed)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override; if unset we derive it from request origin + /api/google/callback.
GOOGLE_OAUTH_REDIRECT_URI=
